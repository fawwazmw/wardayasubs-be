# Copy this file to .env.development (local) or .env.production (deploy)
# The app loads the correct file based on NODE_ENV

DATABASE_URL="postgresql://postgres:password@localhost:5432/wardaya_subs"
JWT_SECRET="change-this-to-a-random-string"
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email (SMTP) - leave empty to disable and use console.log fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# AI Chatbot - Provider: groq (recommended) or gemini
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
